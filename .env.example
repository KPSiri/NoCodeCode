# ── LLM Provider ──────────────────────────────────────────────────────────────

# Google Gemini (required if using Google GenAI)
GOOGLE_API_KEY=your_google_api_key_here

# ── Agent Configuration ────────────────────────────────────────────────────────

# Set to true for verbose per-agent output in the terminal
VERBOSE=false

# Optional: override the default model
# MODEL=gemini-3.5-flash   # Google Gemini example

# ── Observability — Langfuse ───────────────────────────────────────────────────
# Sign up at https://cloud.langfuse.com (free tier available).
# Create a project → Settings → API Keys → copy the public + secret key.
# Leave these blank to disable tracing; the app will still work normally.

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Self-hosted Langfuse: uncomment and set your instance URL
# LANGFUSE_HOST=https://your-langfuse-instance.example.com
